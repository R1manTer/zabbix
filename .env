# =============================================================================
# Zabbix 7.0 LTS — Головний конфігураційний файл
# Проект: zabbix_lab | Сервер моніторингу 500+ пристроїв
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_123!
POSTGRES_DB=zabbix
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Zabbix Server ---
ZBX_SERVER_HOST=0.0.0.0
ZBX_SERVER_PORT=10051

# Пінгери: 40 паралельних процесів для 500+ хостів з інтервалом 5-15 сек
ZBX_STARTPINGERS=40

# Pollers для інших перевірок
ZBX_STARTPOLLERS=10
ZBX_STARTIPMIPOLLERS=0
ZBX_STARTPOLLERSUNREACHABLE=4
ZBX_STARTTRAPPERS=5
ZBX_STARTDISCOVERERS=3
ZBX_STARTHTTPPOLLERS=3

# Cache — оптимізовано для 500 хостів
ZBX_VALUECACHESIZE=256M
ZBX_CACHESIZE=128M
ZBX_HISTORYCACHESIZE=128M
ZBX_HISTORYINDEXCACHESIZE=64M
ZBX_TRENDCACHESIZE=32M

# Housekeeping — критично для RAID 5 (72-140 GB)
# Частота запуску (кожні 1 годину)
ZBX_HOUSEKEEPINGFREQUENCY=1
# Максимальна кількість записів для видалення за один прохід
ZBX_MAXHOUSEKEEPERDELETE=100000

# --- Zabbix Web (Nginx) ---
ZBX_SERVER_NAME=Zabbix Monitoring — Lab
PHP_TZ=Europe/Kyiv
ZBX_MAXEXECUTIONTIME=300
ZBX_MEMORYLIMIT=256M
ZBX_POSTMAXSIZE=32M
ZBX_UPLOADMAXFILESIZE=32M

# --- Порти (зміни при потребі) ---
WEB_PORT=8080
SERVER_PORT=10051
